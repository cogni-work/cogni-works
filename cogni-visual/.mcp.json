{
  "mcpServers": {
    "excalidraw_sketch": {
      "type": "url",
      "url": "https://mcp.excalidraw.com"
    },
    "excalidraw": {
      "command": "bash",
      "args": ["-c", "$HOME/.claude/mcp-servers/mcp_excalidraw/start.sh"],
      "env": {
        "EXPRESS_SERVER_URL": "http://localhost:3000",
        "ENABLE_CANVAS_SYNC": "true"
      }
    }
  }
}
