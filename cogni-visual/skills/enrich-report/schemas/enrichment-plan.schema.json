{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enrichment Plan",
  "description": "Plan of visualizations to inject into a report. Produced by Phase 2, consumed by Phase 4-5.",
  "type": "object",
  "required": ["report_type", "source_path", "density", "total_enrichments", "enrichments"],
  "properties": {
    "report_type": {
      "type": "string",
      "enum": ["trend-report", "research-report", "generic"]
    },
    "source_path": { "type": "string" },
    "density": {
      "type": "string",
      "enum": ["minimal", "balanced", "rich"]
    },
    "total_enrichments": { "type": "integer", "minimum": 0 },
    "enrichments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "track", "target_section", "description", "score"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^enr-\\d{3}$",
            "description": "Unique enrichment ID (enr-001, enr-002, ...)"
          },
          "type": {
            "type": "string",
            "enum": [
              "kpi-dashboard", "horizon-chart", "theme-radar", "coverage-heatmap",
              "distribution-doughnut", "timeline-chart", "comparison-bar", "stat-chart",
              "tips-flow", "relationship-map", "concept-sketch", "process-flow", "summary-card"
            ]
          },
          "track": {
            "type": "string",
            "enum": ["data", "concept", "html"]
          },
          "target_section": {
            "type": "string",
            "description": "Section ID (slugified heading) where enrichment injects"
          },
          "injection_after_line": {
            "type": "integer",
            "description": "Source line number after which to inject (for generator script)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of what this enrichment shows"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "priority": {
            "type": "string",
            "enum": ["structural", "content-detected"],
            "description": "Whether this enrichment was triggered by structural rules or content analysis"
          },
          "data": {
            "type": "object",
            "description": "Extracted data for visualization generation (stats, table rows, chain components, etc.)"
          }
        }
      }
    }
  }
}
